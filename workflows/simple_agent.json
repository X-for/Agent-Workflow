{
  "workflow_id": "simple_agent",
  "description": "极简agent工作流",
  "entry_point": "agent",
  "nodes": [
    {
      "name": "agent",
      "model": "deepseek-chat",
      "temperature": 0.3,
      "system_prompt": "你是一个智能体, 你会根据用户的问题或者自己想到的一些关键词进行搜索并获取网页内容, 总结后告诉用户。",
      "api": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com",
      "output_key": "result",
      "tools": [
          "web_search",
          "get_content_from_url"
      ]
    }
  ],
  "edges": [
    {
      "from": "agent_tools",
      "to": "agent"
    }
  ],
  "conditional_edges": [
    {
      "from": "agent",
      "router": "check_tool_calls",
      "mapping": {
        "execute_tools": "agent_tools",
        "next_step": "END"
      }
    }
  ]
}