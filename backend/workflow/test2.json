{
  "workflow_id": "parallel_research",
  "description": "多分支并行任务解析、多维检索与最终总结结构",
  "entry_point": "parser",
  "nodes": [
    {
      "name": "parser",
      "model": "deepseek-chat",
      "temperature": 0.1,
      "system_prompt": "你是一个任务解析节点。请根据用户输入，拆解出当前任务的核心要素，并输出一段明确的行动指南，以供后续的网络检索、本地检索和深度思考模块使用。",
      "api": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com",
      "output_key": "parsed_query",
      "tools": []
    },
    {
      "name": "web_searcher",
      "model": "deepseek-chat",
      "temperature": 0.3,
      "system_prompt": "你是一个网络检索节点。请结合上下文，调用搜索工具查询外部信息。如果已经获得足够信息，请直接总结你的网络视角结论。",
      "api": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com",
      "output_key": "web_results",
      "tools": [
        "web_search"
      ]
    },
    {
      "name": "local_searcher",
      "model": "deepseek-chat",
      "temperature": 0.1,
      "system_prompt": "你是一个本地检索节点。请利用你的知识库（假设），针对解析出的任务输出纯粹的本地视角的背景资料和解决方案评估。",
      "api": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com",
      "output_key": "local_results",
      "tools": [
        "read_document",
        "list_files_in_directory"
      ]
    },
    {
      "name": "deep_researcher",
      "model": "deepseek-chat",
      "temperature": 0.7,
      "system_prompt": "你是一个深度思考节点。请抛开外部资料，完全依靠第一性原理对当前问题进行深度逻辑推演和发散性思考。",
      "api": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com",
      "output_key": "research_results",
      "tools": []
    },
    {
      "name": "summarizer",
      "model": "deepseek-chat",
      "temperature": 0.4,
      "system_prompt": "你是一个高级汇总节点。请仔细阅读上下文中的 `web_results`、`local_results` 和 `research_results`，将这三个维度的信息进行完美融合，输出一份排版清晰、结构严谨的最终总结报告。",
      "api": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com",
      "output_key": "draft",
      "tools": []
    }
  ],
  "edges": [
    {
      "from": "parser",
      "to": "web_searcher"
    },
    {
      "from": "parser",
      "to": "local_searcher"
    },
    {
      "from": "parser",
      "to": "deep_researcher"
    },
    {
      "from": "tool_executor",
      "to": "web_searcher"
    }
  ],
  "conditional_edges": [
    {
      "from": "web_searcher",
      "router": "tool_or_fan_in_router",
      "router_args": {
        "required_keys": [
          "web_results",
          "local_results",
          "research_results"
        ]
      },
      "mapping": {
        "execute_tools": "tool_executor",
        "ready": "summarizer",
        "wait": "END"
      }
    },
    {
      "from": "local_searcher",
      "router": "fan_in_router",
      "router_args": {
        "required_keys": [
          "web_results",
          "local_results",
          "research_results"
        ]
      },
      "mapping": {
        "ready": "summarizer",
        "wait": "END"
      }
    },
    {
      "from": "deep_researcher",
      "router": "fan_in_router",
      "router_args": {
        "required_keys": [
          "web_results",
          "local_results",
          "research_results"
        ]
      },
      "mapping": {
        "ready": "summarizer",
        "wait": "END"
      }
    }
  ]
}